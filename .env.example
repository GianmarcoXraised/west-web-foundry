# Copy to .env for local dev. On Railway, set these under Variables.

# Session signing secret — set to a long random string in production.
SESSION_SECRET=change-me-to-a-long-random-string

# First superadmin account, created automatically on first boot.
# NEVER commit the real password — set it here / in Railway Variables only.
ADMIN_EMAIL=gianmarco@west-web-foundry.com
ADMIN_PASSWORD=set-a-strong-password
ADMIN_NAME=Gianmarco

# Where new call requests and enquiries are emailed for review.
NOTIFY_EMAIL=gianmarco@west-web-foundry.com

# Your Calendly scheduling link. Used for public "Book a call" and sent to clients
# whose call request you approve.
CALENDLY_URL=https://calendly.com/d/dzzd-7fr-w3q/west-web-foundry

# Public base URL — used for canonical/OG tags and sitemap.
SITE_URL=https://west-web-foundry.com

# SMTP — required to actually SEND emails (call requests / decisions).
# Without these, emails are logged to the server console instead of sent.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=West Web Foundry <hello@west-web-foundry.com>

# Where the JSON database file lives.
# Locally ./data/wwf.db is fine. On Railway, mount a Volume and point this at it,
# e.g. DATABASE_PATH=/data/wwf.db  (otherwise data resets on every redeploy).
DATABASE_PATH=./data/wwf.db

# Optional: PORT is provided automatically by Railway.
# PORT=3000
