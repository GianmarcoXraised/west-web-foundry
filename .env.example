# Copy to .env for local dev. On Railway, set these under Variables.

# Session signing secret — set to a long random string in production.
SESSION_SECRET=change-me-to-a-long-random-string

# First admin account, created automatically on first boot.
ADMIN_EMAIL=gianmarco@xraised.com
ADMIN_PASSWORD=change-this-now
ADMIN_NAME=Gianmarco

# Your Calendly scheduling link (e.g. https://calendly.com/your-handle/intro-call).
# Leave blank until you have it — the "Book a meeting" buttons will fall back to the contact form.
CALENDLY_URL=

# Where the SQLite database file lives.
# Locally ./data/wwf.db is fine. On Railway, mount a Volume and point this at it,
# e.g. DATABASE_PATH=/data/wwf.db  (otherwise data resets on every redeploy).
DATABASE_PATH=./data/wwf.db

# Optional: PORT is provided automatically by Railway.
# PORT=3000
